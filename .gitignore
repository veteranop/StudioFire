# Python
__pycache__/
*.pyc
.venv/
venv/

# Runtime state — never commit
logs/
data/
*.db
*.db-wal
*.db-shm
precache/
config/config.json

# Engine runtime state
queue_state.json
heartbeat.txt

# Binaries (fetched by installer, not vendored)
bin/

# Local media assets (user-managed)
media/

# OS
Thumbs.db
desktop.ini

# demo/test emergency content stays local
assets/emergency/*.mp3

# Installer build outputs (build_payload.py + ISCC downloads/produces these)
installer/payload/
installer/Output/

# Local artifacts
.playwright-mcp/
*.lst

# local screenshots / playwright artifacts
.playwright-mcp/
/*.png

# Obsidian vault config (per-user; not part of the project)
.obsidian/

# Claude Code per-user settings
.claude/settings.local.json

# per-station service drive mapping (copy from drive-map.example.bat)
config/drive-map.bat
